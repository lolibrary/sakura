{
    "name": "lolibrary/sakura",
    "type": "project",
    "description": "Lolibrary's web frontend",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "php": "^8.2",
        "ext-intl": "*",
        "ext-json": "*",
        "ext-pdo": "*",
        "astrotomic/laravel-translatable": "^11.17",
        "blendbyte/nova-attach-many": "^2.0",
        "kiritokatklian/nova-astrotranslatable": "^5.0",
        "laravel/fortify": "^1.36",
        "laravel/framework": "^11.0",
        "laravel/nova": "^5.0",
        "laravel/passport": "^12.0",
        "laravel/tinker": "^2.0",
        "laravel/ui": "^4.0",
        "league/flysystem": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.0",
        "lolibrary/image-array": "^1.0",
        "sentry/sentry-laravel": "^4.0",
        "stevebauman/purify": "^6.0",
        "symfony/http-client": "^6.4",
        "symfony/postmark-mailer": "^6.4",
        "whitecube/nova-flexible-content": "^2.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.0",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^10.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "policy": {
            "advisories": {
                "audit": "report",
                "ignore-id": {
                    "PKSA-3r5d-mb8f-1qw9": "unavoidable audit fail",
                    "PKSA-mdq4-51ck-6kdq": "unavoidable audit fail",
                    "PKSA-m5cs-t1y6-qpcs": "medium, no action yet"
                }
            }
        },
        "audit": {
            "block-insecure": false
        },
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders",
            "Database\\Factories\\": "database/factories"
        },
        "files": [
            "app/Helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://nova.laravel.com"
        },
        {
            "type": "path",
            "url": "./nova-components/ImageArray"
        }
    ]
}
